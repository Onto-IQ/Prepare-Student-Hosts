*credentials*.json
cloudflared-*.json
*.cfargotunnel.json

# SSL/TLS keys
*.key
*.pem
*.crt
*.p12
*.pfx

# SSH keys
.ssh/
id_rsa*
id_ed25519*
*.pub

# Database dumps
*.sql
*.sql.gz
*.dump

