# =============================================================================
# Sensitive Data — ห้าม Commit เด็ดขาด
# =============================================================================

# Environment variables และ secrets
.env
.env.local
.env.*.local
.env.production
.env.development

# ข้อมูลรันจริง (รหัสผ่าน, keys)
data/
backups/

