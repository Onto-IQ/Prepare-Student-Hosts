# =============================================================================
# n8n Class Environment Configuration
# แก้ค่าตามต้องการ แล้วรัน ./scripts/setup-class.sh
# =============================================================================

# --- PostgreSQL (ใช้โดย Postgres + n8n ทุก instance) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=n8n

# --- n8n (timezone) ---
GENERIC_TIMEZONE=Asia/Bangkok

# --- การตั้งค่าครั้งนี้ ---
# โดเมนหลัก — นักเรียนจะเข้าที่ n8n01.BASE_HOST, n8n02.BASE_HOST, ...
# ตัวอย่าง: datafabric.academy หรือ 76.13.219.184.nip.io (ถ้าไม่มีโดเมน)
BASE_HOST=datafabric.academy

# จำนวนนักเรียน/instance ที่ต้องการ
N8N_COUNT=25

# ใช้ Let's Encrypt ไหม? (false = ไม่ใช้, ใช้ Cloudflare หรือ HTTP แทน)
USE_LETSENCRYPT=false

# --- Traefik ---
TRAEFIK_ACME_EMAIL=admin@datafabric.academy

# --- Cloudflare Tunnel (optional) ---
# ถ้าใช้ Cloudflare Tunnel ให้ตั้งค่า TUNNEL_ID แล้วรันสคริปต์ setup-tunnel.sh
# TUNNEL_ID=your-tunnel-id-here
