# --- PostgreSQL (ใช้โดย Postgres + n8n ทุก instance) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_to_a_secure_password or use openssl rand -base64 32
POSTGRES_DB=n8n

# --- n8n (เวลา zone) ---
GENERIC_TIMEZONE=Asia/Bangkok

# --- สำหรับ scripts/generate-compose.py (สร้าง docker-compose.generated.yml) ---
# โดเมนหลัก → แต่ละ instance จะได้ n8n01.BASE_HOST, n8n02.BASE_HOST, ...
# ไม่มีโดเมน: ใช้ nip.io เช่น 76.13.219.184.nip.io (แทนด้วย IP จริงของ VPS)
BASE_HOST=yourdomain.com
# จำนวน n8n instances (default 25 ถ้าไม่ใส่)
# N8N_COUNT=25

# --- Traefik (Let's Encrypt) ---
TRAEFIK_ACME_EMAIL=admin@yourdomain.com
